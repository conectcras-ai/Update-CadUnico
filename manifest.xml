<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns="https://update4j.org/schema/4.0/config" version="1.0.0">
  <base uri="https://raw.githubusercontent.com/conectcras-ai/Update-CadUnico/main/" path="${user.dir}/" />
  <properties>
    <property key="app.name" value="Conect CadUnico" />
    <property key="app.version" value="1.0.0" />
    <property key="vendor" value="SEMAS" />
  </properties>
  <files>
    <file path="app/cadunico-app-1.0.0-all.jar" uri="app/cadunico-app-1.0.0-all.jar" />
  </files>
  <launch>
    <application mainClass="br.semas.sistemas.gestao.cadunico.app.App">
      <classpath>
        <file path="app/cadunico-app-1.0.0-all.jar" />
      </classpath>
      <jvmArgs>
        <arg>-Dfile.encoding=UTF-8</arg>
        <arg>-Duser.timezone=America/Sao_Paulo</arg>
        <arg>-DLOG_DIR=C:/ProgramData/ConectCadUnico/logs</arg>
      </jvmArgs>
    </application>
  </launch>
</configuration>
